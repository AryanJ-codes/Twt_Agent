## Telegram and Slack credentials (fill these in)
TELEGRAM_BOT_TOKEN=your_value_here
TELEGRAM_CHAT_ID=your_value_here
#SLACK_WEBHOOK=your_value_here

# Timezone and posting times (local time)
TZ=your_value_here
MORNING_TIME=your_value_here
MIDDAY_TIME=your_value_here
AFTERNOON_TIME=your_value_here
EVENING_TIME=your_value_here
NIGHT_TIME=your_value_here
MINUTES_BEFORE_POST=your_value_here

# Run mode controls
DRY_RUN=your_value_here
TEST_MODE=your_value_here

# Twitter API credentials (get these from developer.twitter.com)
TW_CONSUMER_KEY=your_value_here
TW_CONSUMER_SECRET=your_value_here
TW_BEARER_TOKEN=your_value_here
TW_ACCESS_TOKEN=your_value_here
TW_ACCESS_TOKEN_SECRET=your_value_here
# OAuth 2.0 Client credentials (from App Settings → OAuth 2.0 Client ID and Secret)
TW_CLIENT_ID=your_value_here
TW_CLIENT_SECRET=your_value_here

# Playwright Web Scraper Credentials (for GUI posting)
TWITTER_EMAIL=your_value_here
TWITTER_USERNAME=your_value_here
TWITTER_PASSWORD=your_value_here
# LLM API keys (free — no credit card needed)
# Groq (primary): https://console.groq.com → API Keys → Create Key
GROQ_API_KEY=your_value_here
# HuggingFace (fallback): https://huggingface.co/settings/tokens → New token
HF_API_KEY=your_value_here
